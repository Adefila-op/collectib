PORT=8787
APP_ORIGIN=http://localhost:5173,https://collectibles-vite.vercel.app
VITE_API_URL=http://localhost:8787
PUBLIC_APP_URL=https://collectibles-vite.vercel.app
JWT_SECRET=replace-with-a-long-random-secret

# Supabase service role credentials belong on the backend only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Helius RPC and webhook guard.
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=replace-with-a-shared-webhook-secret

# Flutterwave checkout API and webhook guard.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-or-live-secret-key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-or-live-public-key
FLUTTERWAVE_ENCRYPTION_KEY=your-flutterwave-encryption-key
FLUTTERWAVE_SECRET_HASH=your-flutterwave-secret-hash
PAYMENT_REDIRECT_URL=https://collectibles-vite.vercel.app/checkout/success

# Email verification and password reset are sent by Supabase Auth.

# Used by /api/cron/supabase-ping.
CRON_SECRET=replace-with-a-cron-secret
