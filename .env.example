PORT=8787
APP_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:8787
PUBLIC_APP_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret

# Supabase service role credentials belong on the backend only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Helius RPC and webhook guard.
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=replace-with-a-shared-webhook-secret

# Flutterwave sends this value in the verif-hash header.
FLUTTERWAVE_SECRET_HASH=your-flutterwave-secret-hash

# Brevo SMTP for verification and password reset emails.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
BREVO_SMTP_USER=b0139c001@smtp-brevo.com
BREVO_SMTP_KEY=your-brevo-smtp-key
SMTP_FROM_EMAIL=no-reply@collectibles.pics
SMTP_FROM_NAME=Collectibles

# Used by /api/cron/supabase-ping.
CRON_SECRET=replace-with-a-cron-secret
